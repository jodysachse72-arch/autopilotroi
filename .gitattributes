# Normalize line endings — every text file is LF in the repo, regardless of OS.
# This ends the CRLF/LF churn caused by editing on Windows.
* text=auto eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary

# Lock files — keep verbatim
package-lock.json text eol=lf
yarn.lock         text eol=lf

# Source files — explicit LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
